<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgDark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/profileBottomNav"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="28dp"
            android:paddingBottom="20dp">

            <!-- Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My Profile"
                android:textColor="@color/textWhite"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"/>

            <!-- Avatar + name card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bgCard"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">

                    <!-- Avatar circle -->
                    <TextView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:text="👤"
                        android:textSize="40sp"
                        android:gravity="center"
                        android:background="@drawable/bg_circle_green"
                        android:layout_marginBottom="14dp"/>

                    <TextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User"
                        android:textColor="@color/textWhite"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvProfileUsername"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@username"
                        android:textColor="@color/textGray"
                        android:textSize="14sp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvProfileArea"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍 Mumbai"
                        android:textColor="@color/greenNavActive"
                        android:textSize="13sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Stats card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bgCard"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <!-- Trees -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvProfileTrees"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/greenNavActive"
                            android:textSize="24sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌳 Trees"
                            android:textColor="@color/textGray"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <!-- Points -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvProfilePoints"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/greenNavActive"
                            android:textSize="24sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐ Points"
                            android:textColor="@color/textGray"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <!-- Badge -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvProfileBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌍"
                            android:textSize="24sp"/>
                        <TextView
                            android:id="@+id/tvProfileBadgeLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Eco Starter"
                            android:textColor="@color/textGray"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Language toggle button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLanguage"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🌐  Switch to Marathi / मराठी"
                android:textColor="@color/textWhite"
                android:textSize="14sp"
                android:backgroundTint="@color/bgCard"
                app:cornerRadius="26dp"
                android:layout_marginBottom="12dp"/>

            <!-- Leaderboard button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewLeaderboard"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🏆  View Leaderboard"
                android:textColor="@color/textWhite"
                android:textSize="15sp"
                android:backgroundTint="@color/bgCard"
                app:cornerRadius="26dp"
                android:layout_marginBottom="12dp"/>

            <!-- River Reports card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardRiverReports"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bgCard"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌊 My River Reports"
                        android:textColor="@color/textWhite"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:id="@+id/tvNoRiverReports"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No river reports submitted yet."
                        android:textColor="@color/textGray"
                        android:textSize="12sp"/>

                    <LinearLayout
                        android:id="@+id/riverReportsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Logout button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🚪  Log Out"
                android:textColor="@color/textWhite"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#C62828"
                app:cornerRadius="26dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/profileBottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:background="@color/bgNavBar"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout android:id="@+id/navHome" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🏠" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_home" android:textColor="@color/textGray" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navScan" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📷" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_scan" android:textColor="@color/textGray" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navTrack" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📊" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_track" android:textColor="@color/textGray" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navTrees" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🌲" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_trees" android:textColor="@color/textGray" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navTerritory" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🗺" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_territory" android:textColor="@color/textGray" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navNGOs" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👥" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_ngos" android:textColor="@color/textGray" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navProfile" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/bg_nav_active_pill">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👤" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_profile" android:textColor="@color/greenNavActive" android:textSize="10sp"/>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
