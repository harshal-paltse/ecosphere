<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgDark">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/chatHeader"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentTop="true"
        android:background="@color/bgCard"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="🤖"
            android:textSize="22sp"
            android:gravity="center"
            android:background="@drawable/bg_circle_green"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EcoBot"
                android:textColor="@color/textWhite"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Carbon &amp; River Expert"
                android:textColor="@color/greenNavActive"
                android:textSize="11sp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/btnChatClose"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="✕"
            android:textColor="@color/textGray"
            android:textSize="18sp"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Quick topic chips -->
    <HorizontalScrollView
        android:id="@+id/chipScroll"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_below="@id/chatHeader"
        android:scrollbars="none"
        android:background="@color/bgDark"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <LinearLayout
            android:id="@+id/chipContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"/>
    </HorizontalScrollView>

    <!-- Chat messages -->
    <ScrollView
        android:id="@+id/chatScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/chipScroll"
        android:layout_above="@id/inputBar"
        android:scrollbars="none"
        android:padding="12dp">

        <LinearLayout
            android:id="@+id/chatMessages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </ScrollView>

    <!-- Input bar -->
    <LinearLayout
        android:id="@+id/inputBar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:background="@color/bgCard"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <EditText
            android:id="@+id/etChatInput"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:hint="Ask me anything..."
            android:textColor="@color/textWhite"
            android:textColorHint="@color/textGray"
            android:textSize="14sp"
            android:background="@color/bgCardAlt"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:inputType="text"
            android:imeOptions="actionSend"
            android:maxLines="1"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSend"
            android:layout_width="48dp"
            android:layout_height="42dp"
            android:text="➤"
            android:textColor="@color/textWhite"
            android:textSize="16sp"
            android:backgroundTint="@color/colorPrimary"
            app:cornerRadius="21dp"
            android:layout_marginStart="8dp"
            app:iconPadding="0dp"/>
    </LinearLayout>

</RelativeLayout>
