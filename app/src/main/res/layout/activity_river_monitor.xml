<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgDark">

    <LinearLayout
        android:id="@+id/riverHeader"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentTop="true"
        android:background="@color/bgCard"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <TextView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="River"
            android:textSize="12sp"
            android:gravity="center"
            android:background="@drawable/bg_circle_blue"/>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="River Monitor"
                android:textColor="@color/textWhite"
                android:textSize="16sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Report pollution with photo + GPS"
                android:textColor="@color/greenNavActive"
                android:textSize="11sp"/>
        </LinearLayout>
        <TextView
            android:id="@+id/btnRiverClose"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="X"
            android:textColor="@color/textGray"
            android:textSize="18sp"
            android:gravity="center"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/riverHeader"
        android:scrollbars="none"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Photo preview card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="200dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bgCard"
                android:layout_marginBottom="12dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <LinearLayout
                        android:id="@+id/riverPhotoPlaceholder"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📷"
                            android:textSize="32sp"
                            android:gravity="center"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Take or upload a photo of the polluted river"
                            android:textColor="@color/textGray"
                            android:textSize="13sp"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>
                    <ImageView
                        android:id="@+id/ivRiverPhoto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Camera + Gallery buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCaptureRiver"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="📷 Camera"
                    android:textColor="@color/textWhite"
                    android:textSize="13sp"
                    android:backgroundTint="@color/colorPrimary"
                    app:cornerRadius="24dp"
                    android:layout_marginEnd="6dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGalleryRiver"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="🖼 Gallery"
                    android:textColor="@color/textWhite"
                    android:textSize="13sp"
                    android:backgroundTint="@color/bgCard"
                    app:cornerRadius="24dp"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>

            <!-- GPS Location -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bgCard"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GPS Location (auto-detected)"
                        android:textColor="@color/textGray"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/tvRiverLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fetching location..."
                        android:textColor="@color/greenNavActive"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Description -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bgCard"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Describe the pollution"
                        android:textColor="@color/textGray"
                        android:textSize="12sp"
                        android:layout_marginBottom="6dp"/>
                    <EditText
                        android:id="@+id/etRiverDescription"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:hint="e.g. Industrial waste, plastic, oil spill..."
                        android:textColor="@color/textWhite"
                        android:textColorHint="@color/textGray"
                        android:textSize="13sp"
                        android:background="@null"
                        android:inputType="textMultiLine"
                        android:gravity="top"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Report button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReportRiver"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Report Pollution to NGO and NMC"
                android:textColor="@color/textWhite"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="@color/colorPrimary"
                app:cornerRadius="26dp"
                android:layout_marginBottom="16dp"/>

            <!-- Timer card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/timerCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bgCard"
                android:layout_marginBottom="12dp"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp"
                    android:gravity="center_horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Time Since Report"
                        android:textColor="@color/textGray"
                        android:textSize="12sp"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:id="@+id/tvTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00:00"
                        android:textColor="@color/textWhite"
                        android:textSize="42sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>
                    <TextView
                        android:id="@+id/tvTimerStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Waiting for response..."
                        android:textColor="@color/textGray"
                        android:textSize="12sp"
                        android:layout_marginTop="6dp"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMarkResolved"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Mark as Resolved"
                        android:textSize="12sp"
                        android:textColor="@color/textWhite"
                        android:backgroundTint="@color/greenDim"
                        app:cornerRadius="20dp"
                        android:layout_marginTop="12dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- My Reports -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bgCard"
                android:layout_marginBottom="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="My Reports"
                        android:textColor="@color/textWhite"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:id="@+id/tvNoReports"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No reports yet. Be the first to report!"
                        android:textColor="@color/textGray"
                        android:textSize="12sp"/>
                    <LinearLayout
                        android:id="@+id/reportsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>
