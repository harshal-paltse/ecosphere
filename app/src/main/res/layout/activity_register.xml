<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgDark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌱"
            android:textSize="56sp"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textColor="@color/textWhite"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Join the eco community 🌍"
            android:textColor="@color/textGray"
            android:textSize="13sp"
            android:layout_marginBottom="36dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bgCard"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email Address"
                    android:textColor="@color/textGray"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp"/>
                <EditText
                    android:id="@+id/etRegEmail"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="e.g. you@email.com"
                    android:textColor="@color/textWhite"
                    android:textColorHint="@color/textGray"
                    android:background="@color/bgCardAlt"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:inputType="textEmailAddress"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Full Name"
                    android:textColor="@color/textGray"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp"/>
                <EditText
                    android:id="@+id/etRegName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Your full name"
                    android:textColor="@color/textWhite"
                    android:textColorHint="@color/textGray"
                    android:background="@color/bgCardAlt"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:inputType="textPersonName"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Username"
                    android:textColor="@color/textGray"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp"/>
                <EditText
                    android:id="@+id/etRegUsername"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Choose a username"
                    android:textColor="@color/textWhite"
                    android:textColorHint="@color/textGray"
                    android:background="@color/bgCardAlt"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:inputType="text"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your Area / City"
                    android:textColor="@color/textGray"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp"/>
                <Spinner
                    android:id="@+id/spinnerRegArea"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:entries="@array/area_list"
                    android:background="@color/bgCardAlt"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textColor="@color/textGray"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp"/>
                <EditText
                    android:id="@+id/etRegPassword"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Create a password"
                    android:textColor="@color/textWhite"
                    android:textColorHint="@color/textGray"
                    android:background="@color/bgCardAlt"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:inputType="textPassword"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Confirm Password"
                    android:textColor="@color/textGray"
                    android:textSize="12sp"
                    android:layout_marginBottom="6dp"/>
                <EditText
                    android:id="@+id/etRegConfirm"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Re-enter password"
                    android:textColor="@color/textWhite"
                    android:textColorHint="@color/textGray"
                    android:background="@color/bgCardAlt"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:inputType="textPassword"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Create Account"
            android:textColor="@color/textWhite"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/colorPrimary"
            app:cornerRadius="26dp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account? "
                android:textColor="@color/textGray"
                android:textSize="14sp"/>
            <TextView
                android:id="@+id/tvGoLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Log In"
                android:textColor="@color/colorPrimary"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
