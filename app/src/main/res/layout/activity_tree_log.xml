<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgDark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/treeBottomNav"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <!-- Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌳 Plant a Tree"
                android:textColor="@color/textWhite"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Capture photo + GPS to verify planting"
                android:textColor="@color/textGray"
                android:textSize="13sp"
                android:layout_marginBottom="20dp"/>

            <!-- Photo capture card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bgCard"
                android:layout_marginBottom="12dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Placeholder when no photo -->
                    <LinearLayout
                        android:id="@+id/photoPlaceholder"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📷"
                            android:textSize="48sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Take a photo of the tree you planted"
                            android:textColor="@color/textGray"
                            android:textSize="13sp"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>

                    <!-- Photo preview -->
                    <ImageView
                        android:id="@+id/ivTreePhoto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Capture button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCapture"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="📷 Capture Photo"
                android:textColor="@color/textWhite"
                android:textSize="14sp"
                android:backgroundTint="@color/colorPrimary"
                app:cornerRadius="24dp"
                android:layout_marginBottom="16dp"/>

            <!-- GPS Location card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bgCard"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GPS Location (auto-detected)"
                        android:textColor="@color/textGray"
                        android:textSize="12sp"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tvLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍 Fetching location..."
                        android:textColor="@color/greenNavActive"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:visibility="visible"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Log Tree button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogTrees"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🌱 Log This Tree"
                android:textColor="@color/textWhite"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@color/colorPrimary"
                app:cornerRadius="26dp"
                android:layout_marginBottom="20dp"/>

            <!-- Stats Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/treeStatsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bgCard"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvTotalTrees"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/textWhite"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textAlignment="center"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tvCO2Reduced"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/greenNavActive"
                        android:textSize="14sp"
                        android:textAlignment="center"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:id="@+id/tvTreeBadge"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/textWhite"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textAlignment="center"
                        android:background="@drawable/bg_badge_green"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:layout_marginBottom="12dp"
                        android:visibility="gone"/>

                    <ProgressBar
                        android:id="@+id/pbTrees"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="10dp"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="@color/colorPrimary"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Progress toward 10-tree goal"
                        android:textColor="@color/textGray"
                        android:textSize="11sp"
                        android:textAlignment="center"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnBackTree"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="← Back"
                android:backgroundTint="@color/bgCard"
                android:textColor="@color/textGray"/>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/treeBottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:background="@color/bgNavBar"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout android:id="@+id/navHome" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🏠" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_home" android:textColor="@color/textGray" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navScan" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📷" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_scan" android:textColor="@color/textGray" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navTrack" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📊" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_track" android:textColor="@color/textGray" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navTrees" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/bg_nav_active_pill">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🌲" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_trees" android:textColor="@color/greenNavActive" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navTerritory" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🗺" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_territory" android:textColor="@color/textGray" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navNGOs" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👥" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_ngos" android:textColor="@color/textGray" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navProfile" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👤" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_profile" android:textColor="@color/textGray" android:textSize="10sp"/>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
