<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgDark">

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/scanBottomNav"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/scan_title"
                    android:textColor="@color/textWhite"
                    android:textSize="24sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/scan_subtitle"
                    android:textColor="@color/textGray"
                    android:textSize="13sp"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ResNet50"
                android:textColor="@color/greenNavActive"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_green"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"/>
        </RelativeLayout>

        <!-- Camera viewfinder card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bgCard"
            android:layout_marginBottom="24dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- Preview image (shows captured/selected image) -->
                <ImageView
                    android:id="@+id/ivPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"/>

                <!-- Viewfinder overlay -->
                <LinearLayout
                    android:id="@+id/viewfinderOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <!-- Corner frame drawn via custom view -->
                    <com.example.carboncalculator.ViewfinderView
                        android:layout_width="200dp"
                        android:layout_height="200dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/scan_prompt"
                        android:textColor="@color/textGray"
                        android:textSize="14sp"
                        android:layout_marginTop="16dp"/>
                </LinearLayout>

                <!-- Result overlay (shown after detection) -->
                <LinearLayout
                    android:id="@+id/resultOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:orientation="vertical"
                    android:background="@drawable/bg_result_overlay"
                    android:padding="16dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvWasteType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/textWhite"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvWasteConfidence"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/greenNavActive"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:id="@+id/tvWasteTip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/textGray"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- Cleanup timer badge (top-right corner of image) -->
                <LinearLayout
                    android:id="@+id/timerBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentEnd="true"
                    android:orientation="vertical"
                    android:background="@drawable/bg_result_overlay"
                    android:padding="10dp"
                    android:gravity="center"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏱ Uncleaned"
                        android:textColor="@color/badgeOrange"
                        android:textSize="10sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00"
                        android:textColor="@color/textWhite"
                        android:textSize="20sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <!-- Buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCapture"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="@string/btn_capture"
                android:textColor="@color/textWhite"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="@color/colorPrimary"
                android:layout_marginEnd="10dp"
                app:cornerRadius="26dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpload"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="@string/btn_upload"
                android:textColor="@color/textWhite"
                android:textSize="15sp"
                android:backgroundTint="@color/bgCard"
                app:cornerRadius="26dp"/>
        </LinearLayout>

        <!-- Cleanup danger panel — shown after image upload/capture -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cleanupPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bgCard"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_not_cleaned"
                        android:textColor="@color/badgeOrange"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvCleanupTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Day 1  00s"
                        android:textColor="@color/textWhite"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_rank_pill"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"/>
                </LinearLayout>

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/disadvantagesList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>
                </ScrollView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMarkCleaned"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="@string/btn_mark_cleaned"
                    android:textColor="@color/textWhite"
                    android:textSize="13sp"
                    android:backgroundTint="@color/colorPrimary"
                    android:layout_marginTop="10dp"
                    app:cornerRadius="22dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Emergency Contacts -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bgCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_emergency_contacts"
                    android:textColor="@color/textWhite"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <!-- NMC Nashik -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_rank_pill"
                    android:padding="12dp"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="📞"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:background="@drawable/bg_circle_green"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NMC Nashik"
                            android:textColor="@color/textWhite"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0253-2575631"
                            android:textColor="@color/textGray"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCall0"
                        android:layout_width="72dp"
                        android:layout_height="40dp"
                        android:text="Call"
                        android:textColor="@color/textWhite"
                        android:textSize="13sp"
                        android:backgroundTint="@color/colorPrimary"
                        app:cornerRadius="20dp"/>
                </LinearLayout>

                <!-- Eco Nashik NGO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_rank_pill"
                    android:padding="12dp"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="📞"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:background="@drawable/bg_circle_green"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Eco Nashik NGO"
                            android:textColor="@color/textWhite"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+91 98230 00000"
                            android:textColor="@color/textGray"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCall1"
                        android:layout_width="72dp"
                        android:layout_height="40dp"
                        android:text="Call"
                        android:textColor="@color/textWhite"
                        android:textSize="13sp"
                        android:backgroundTint="@color/colorPrimary"
                        app:cornerRadius="20dp"/>
                </LinearLayout>

                <!-- River Clean Force -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_rank_pill"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="📞"
                        android:textSize="18sp"
                        android:gravity="center"
                        android:background="@drawable/bg_circle_green"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="River Clean Force"
                            android:textColor="@color/textWhite"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+91 94222 00000"
                            android:textColor="@color/textGray"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCall2"
                        android:layout_width="72dp"
                        android:layout_height="40dp"
                        android:text="Call"
                        android:textColor="@color/textWhite"
                        android:textSize="13sp"
                        android:backgroundTint="@color/colorPrimary"
                        app:cornerRadius="20dp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/scanBottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:background="@color/bgNavBar"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout android:id="@+id/navHome" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🏠" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_home" android:textColor="@color/textGray" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navScan" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/bg_nav_active_pill">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📷" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_scan" android:textColor="@color/greenNavActive" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navTrack" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📊" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_track" android:textColor="@color/textGray" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navTrees" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🌲" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_trees" android:textColor="@color/textGray" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navTerritory" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🗺" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_territory" android:textColor="@color/textGray" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navNGOs" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👥" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_ngos" android:textColor="@color/textGray" android:textSize="10sp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navProfile" android:layout_width="0dp"
            android:layout_height="match_parent" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👤" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_profile" android:textColor="@color/textGray" android:textSize="10sp"/>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
