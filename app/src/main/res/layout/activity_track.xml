<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bgDark">

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/trackBottomNav"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="16dp">

            <!-- Top bar: Title + rank badge + menu -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Carbon Tracker"
                        android:textColor="@color/textWhite"
                        android:textSize="24sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calculate your daily footprint"
                        android:textColor="@color/textGray"
                        android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_alignParentEnd="true">

                    <TextView
                        android:id="@+id/tvRankBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="#42"
                        android:textColor="@color/textWhite"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_rank_pill"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⋮"
                        android:textColor="@color/textWhite"
                        android:textSize="22sp"
                        android:paddingStart="10dp"/>
                </LinearLayout>
            </RelativeLayout>

            <!-- Today's Footprint Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bgCard"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Today's Footprint"
                        android:textColor="@color/textGray"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom">

                        <TextView
                            android:id="@+id/tvFootprintValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0"
                            android:textColor="@color/textWhite"
                            android:textSize="52sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" kg CO₂"
                            android:textColor="@color/textGray"
                            android:textSize="18sp"
                            android:paddingBottom="10dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌿 "
                            android:textSize="14sp"/>

                        <TextView
                            android:id="@+id/tvImpactLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Low Impact — Great job!"
                            android:textColor="@color/textGray"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Last 7 Days Chart Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bgCard"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Last 7 Days"
                            android:textColor="@color/textWhite"
                            android:textSize="16sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvWeekAvg"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Avg: 0.0 kg"
                            android:textColor="@color/textGray"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <com.example.carboncalculator.WeeklyChartView
                        android:id="@+id/weeklyChart"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Daily Activities Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bgCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Daily Activities"
                        android:textColor="@color/textWhite"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Adjust to calculate"
                        android:textColor="@color/textGray"
                        android:textSize="12sp"
                        android:layout_marginBottom="20dp"/>

                    <!-- Travel -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_alignParentStart="true">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🚗 " android:textSize="16sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Travel" android:textColor="@color/textWhite"
                                android:textSize="15sp" android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_alignParentEnd="true">

                            <TextView
                                android:id="@+id/tvTravelKm"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 km"
                                android:textColor="@color/textGray"
                                android:textSize="13sp"
                                android:layout_marginEnd="8dp"/>

                            <TextView
                                android:id="@+id/tvTravelKg"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.0 kg"
                                android:textColor="@color/textWhite"
                                android:textSize="12sp"
                                android:background="@drawable/bg_kg_pill"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp"/>
                        </LinearLayout>
                    </RelativeLayout>

                    <SeekBar
                        android:id="@+id/seekTravel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="200"
                        android:progress="0"
                        android:progressTint="@color/textGray"
                        android:thumbTint="@color/textWhite"
                        android:layout_marginBottom="20dp"/>

                    <!-- Electricity -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_alignParentStart="true">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="⚡ " android:textSize="16sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Electricity" android:textColor="@color/textWhite"
                                android:textSize="15sp" android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_alignParentEnd="true">

                            <TextView
                                android:id="@+id/tvElecKwh"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 kWh"
                                android:textColor="@color/textGray"
                                android:textSize="13sp"
                                android:layout_marginEnd="8dp"/>

                            <TextView
                                android:id="@+id/tvElecKg"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.0 kg"
                                android:textColor="@color/textWhite"
                                android:textSize="12sp"
                                android:background="@drawable/bg_kg_pill"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp"/>
                        </LinearLayout>
                    </RelativeLayout>

                    <SeekBar
                        android:id="@+id/seekElectricity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="@color/textGray"
                        android:thumbTint="@color/textWhite"
                        android:layout_marginBottom="20dp"/>

                    <!-- Meat Meals -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_alignParentStart="true">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🍽 " android:textSize="16sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Meat Meals" android:textColor="@color/textWhite"
                                android:textSize="15sp" android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_alignParentEnd="true">

                            <TextView
                                android:id="@+id/tvMeatServings"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 servings"
                                android:textColor="@color/textGray"
                                android:textSize="13sp"
                                android:layout_marginEnd="8dp"/>

                            <TextView
                                android:id="@+id/tvMeatKg"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.0 kg"
                                android:textColor="@color/textWhite"
                                android:textSize="12sp"
                                android:background="@drawable/bg_kg_pill"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp"/>
                        </LinearLayout>
                    </RelativeLayout>

                    <SeekBar
                        android:id="@+id/seekMeat"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="10"
                        android:progress="0"
                        android:progressTint="@color/textGray"
                        android:thumbTint="@color/textWhite"
                        android:layout_marginBottom="20dp"/>

                    <!-- Water -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_alignParentStart="true">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="〰 " android:textSize="16sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Water" android:textColor="@color/textWhite"
                                android:textSize="15sp" android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_alignParentEnd="true">

                            <TextView
                                android:id="@+id/tvWaterL"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 L"
                                android:textColor="@color/textGray"
                                android:textSize="13sp"
                                android:layout_marginEnd="8dp"/>

                            <TextView
                                android:id="@+id/tvWaterKg"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.0 kg"
                                android:textColor="@color/textWhite"
                                android:textSize="12sp"
                                android:background="@drawable/bg_kg_pill"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="4dp"
                                android:paddingBottom="4dp"/>
                        </LinearLayout>
                    </RelativeLayout>

                    <SeekBar
                        android:id="@+id/seekWater"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="500"
                        android:progress="0"
                        android:progressTint="@color/textGray"
                        android:thumbTint="@color/textWhite"
                        android:layout_marginBottom="20dp"/>

                    <!-- Waste -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_alignParentStart="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🗑 " android:textSize="16sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Waste" android:textColor="@color/textWhite"
                                android:textSize="15sp" android:textStyle="bold"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_alignParentEnd="true">
                            <TextView android:id="@+id/tvWasteKgLabel"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0 kg" android:textColor="@color/textGray"
                                android:textSize="13sp" android:layout_marginEnd="8dp"/>
                            <TextView android:id="@+id/tvWasteKg"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0.0 kg" android:textColor="@color/textWhite"
                                android:textSize="12sp" android:background="@drawable/bg_kg_pill"
                                android:paddingStart="10dp" android:paddingEnd="10dp"
                                android:paddingTop="4dp" android:paddingBottom="4dp"/>
                        </LinearLayout>
                    </RelativeLayout>
                    <SeekBar android:id="@+id/seekWaste"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:max="50" android:progress="0"
                        android:progressTint="@color/textGray" android:thumbTint="@color/textWhite"
                        android:layout_marginBottom="20dp"/>

                    <!-- Shopping -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_alignParentStart="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🛒 " android:textSize="16sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Shopping" android:textColor="@color/textWhite"
                                android:textSize="15sp" android:textStyle="bold"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_alignParentEnd="true">
                            <TextView android:id="@+id/tvShoppingItems"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0 items" android:textColor="@color/textGray"
                                android:textSize="13sp" android:layout_marginEnd="8dp"/>
                            <TextView android:id="@+id/tvShoppingKg"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0.0 kg" android:textColor="@color/textWhite"
                                android:textSize="12sp" android:background="@drawable/bg_kg_pill"
                                android:paddingStart="10dp" android:paddingEnd="10dp"
                                android:paddingTop="4dp" android:paddingBottom="4dp"/>
                        </LinearLayout>
                    </RelativeLayout>
                    <SeekBar android:id="@+id/seekShopping"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:max="20" android:progress="0"
                        android:progressTint="@color/textGray" android:thumbTint="@color/textWhite"
                        android:layout_marginBottom="20dp"/>

                    <!-- Digital -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_alignParentStart="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="💻 " android:textSize="16sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Digital" android:textColor="@color/textWhite"
                                android:textSize="15sp" android:textStyle="bold"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center_vertical"
                            android:layout_alignParentEnd="true">
                            <TextView android:id="@+id/tvDigitalHours"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0 hours" android:textColor="@color/textGray"
                                android:textSize="13sp" android:layout_marginEnd="8dp"/>
                            <TextView android:id="@+id/tvDigitalKg"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0.0 kg" android:textColor="@color/textWhite"
                                android:textSize="12sp" android:background="@drawable/bg_kg_pill"
                                android:paddingStart="10dp" android:paddingEnd="10dp"
                                android:paddingTop="4dp" android:paddingBottom="4dp"/>
                        </LinearLayout>
                    </RelativeLayout>
                    <SeekBar android:id="@+id/seekDigital"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:max="24" android:progress="0"
                        android:progressTint="@color/textGray" android:thumbTint="@color/textWhite"
                        android:layout_marginBottom="24dp"/>

                    <!-- Calculate Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCalculate"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="🧮  Calculate CO₂ Emissions"
                        android:textSize="15sp"
                        android:textColor="@color/textWhite"
                        android:textStyle="bold"
                        android:backgroundTint="@color/colorPrimary"
                        app:cornerRadius="26dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/trackBottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:background="@color/bgNavBar"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Home -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🏠" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_home" android:textColor="@color/textGray" android:textSize="10sp"/>
        </LinearLayout>

        <!-- Scan -->
        <LinearLayout
            android:id="@+id/navScan"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📷" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_scan" android:textColor="@color/textGray" android:textSize="10sp"/>
        </LinearLayout>

        <!-- Track (active) -->
        <LinearLayout
            android:id="@+id/navTrack"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_nav_active_pill">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📊" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_track" android:textColor="@color/greenNavActive" android:textSize="10sp"/>
        </LinearLayout>

        <!-- Trees -->
        <LinearLayout
            android:id="@+id/navTrees"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🌲" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_trees" android:textColor="@color/textGray" android:textSize="10sp"/>
        </LinearLayout>

        <!-- Territory -->
        <LinearLayout
            android:id="@+id/navTerritory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🗺" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_territory" android:textColor="@color/textGray" android:textSize="10sp"/>
        </LinearLayout>

        <!-- NGOs -->
        <LinearLayout
            android:id="@+id/navNGOs"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👥" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_ngos" android:textColor="@color/textGray" android:textSize="10sp"/>
        </LinearLayout>

        <!-- Profile -->
        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👤" android:textSize="20sp" android:gravity="center"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_profile" android:textColor="@color/textGray" android:textSize="10sp"/>
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
